@namespace SleepEditWeb.Components.SleepNote

<div class="container-fluid p-3">
    <div class="row">
        <div class="col-lg-6">
            <fieldset class="border rounded p-2 mb-3">
                <legend class="w-auto px-2 fs-6 fw-semibold">Study Performed</legend>
                <div class="form-check">
                    <input class="form-check-input" type="radio" id="studyPsg"
                           checked="@(_studyType == StudyType.Polysomnogram)"
                           @onchange="() => OnStudyTypeChanged(StudyType.Polysomnogram)" />
                    <label class="form-check-label" for="studyPsg">Polysomnogram (PSG)</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" id="studyTitration"
                           checked="@(_studyType == StudyType.CpapBipapTitration)"
                           @onchange="() => OnStudyTypeChanged(StudyType.CpapBipapTitration)" />
                    <label class="form-check-label" for="studyTitration">CPAP/BIPAP Titration</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" id="studySplit"
                           checked="@(_studyType == StudyType.SplitNight)"
                           @onchange="() => OnStudyTypeChanged(StudyType.SplitNight)" />
                    <label class="form-check-label" for="studySplit">Split Night</label>
                </div>
            </fieldset>

            <fieldset class="border rounded p-2 mb-3">
                <legend class="w-auto px-2 fs-6 fw-semibold">Body Position</legend>
                @foreach (var pos in new[] { "Supine", "Lateral", "Prone" })
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="pos_@pos"
                               checked="@_bodyPositions.Contains(pos)"
                               @onchange="e => ToggleSetItem(_bodyPositions, pos, (bool)e.Value!)" />
                        <label class="form-check-label" for="pos_@pos">@pos</label>
                    </div>
                }
            </fieldset>

            <fieldset class="border rounded p-2 mb-3">
                <legend class="w-auto px-2 fs-6 fw-semibold">Snoring</legend>
                @foreach (var level in new[] { "Mild", "Moderate", "Loud" })
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="snore_@level"
                               checked="@_snoringLevels.Contains(level)"
                               @onchange="e => ToggleSetItem(_snoringLevels, level, (bool)e.Value!)" />
                        <label class="form-check-label" for="snore_@level">@level</label>
                    </div>
                }
            </fieldset>

            <fieldset class="border rounded p-2 mb-3">
                <legend class="w-auto px-2 fs-6 fw-semibold">Events</legend>
                @foreach (var (key, label) in new[] { ("RespiratoryEvents", "Respiratory Events"), ("PLMs", "PLMs") })
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="evt_@key"
                               checked="@_events.Contains(key)"
                               @onchange="e => ToggleSetItem(_events, key, (bool)e.Value!)" />
                        <label class="form-check-label" for="evt_@key">@label</label>
                    </div>
                }

                <div class="arrhythmia-control mt-3">
                    <label class="form-label fw-semibold mb-1" id="arrhythmiaPickerLabel">
                        Arrhythmias
                    </label>
                    <details class="arrhythmia-picker">
                        <summary class="arrhythmia-picker-summary"
                                 aria-labelledby="arrhythmiaPickerLabel">
                            <span>@ArrhythmiaSelectionSummary</span>
                            <span class="arrhythmia-picker-count" aria-hidden="true">@_arrhythmias.Count</span>
                        </summary>
                        <div class="arrhythmia-picker-menu"
                             role="group"
                             aria-labelledby="arrhythmiaPickerLabel">
                            @foreach (var option in ArrhythmiaCatalog.Common)
                            {
                                <div class="form-check arrhythmia-option">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="arrhythmia_@option.Id"
                                           checked="@_arrhythmias.Contains(option.Id)"
                                           @onchange="e => ToggleSetItem(_arrhythmias, option.Id, (bool)e.Value!)" />
                                    <label class="form-check-label" for="arrhythmia_@option.Id">
                                        @option.DisplayName
                                    </label>
                                </div>
                            }
                        </div>
                    </details>

                    <div class="arrhythmia-preview mt-2" aria-live="polite">
                        <span class="arrhythmia-preview-label">Note preview</span>
                        <span>@ArrhythmiaNarrativePreview</span>
                    </div>
                </div>
            </fieldset>

            <fieldset class="border rounded p-2 mb-3">
                <legend class="w-auto px-2 fs-6 fw-semibold">Miscellaneous</legend>
                @foreach (var (key, label) in new[] {
                    ("TooLateForCpap", "Too late for CPAP"),
                    ("NoSplitNightCriteria", "No split night criteria")
                })
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="misc_@key"
                               checked="@_miscOptions.Contains(key)"
                               @onchange="e => ToggleSetItem(_miscOptions, key, (bool)e.Value!)" />
                        <label class="form-check-label" for="misc_@key">@label</label>
                    </div>
                }
            </fieldset>

            <fieldset class="border rounded p-2 mb-3">
                <legend class="w-auto px-2 fs-6 fw-semibold">Effects</legend>
                @foreach (var (key, label) in new[] { ("PositionEffect", "Position Effect"), ("RemEffect", "REM Effect") })
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="eff_@key"
                               checked="@_effects.Contains(key)"
                               @onchange="e => ToggleSetItem(_effects, key, (bool)e.Value!)" />
                        <label class="form-check-label" for="eff_@key">@label</label>
                    </div>
                }
            </fieldset>
        </div>

        <div class="col-lg-6">
            @if (ShowTitrationControls)
            {
                <fieldset class="border rounded p-2 mb-3">
                    <legend class="w-auto px-2 fs-6 fw-semibold">PAP Therapy Course</legend>

                    @for (var i = 0; i < _therapyStages.Count; i++)
                    {
                        var stageIndex = i;
                        var stage = _therapyStages[stageIndex];

                        <section class="therapy-stage @(stageIndex > 0 ? "therapy-stage-transition" : null)">
                            <div class="therapy-stage-heading">
                                <span>@(stageIndex == 0 ? "Therapy started with" : "Changed to")</span>
                                <span class="badge bg-secondary">Stage @(stageIndex + 1)</span>
                            </div>

                            <div class="d-flex flex-wrap gap-3 mb-2">
                                @foreach (var mode in GetAvailableModesForStage(stageIndex))
                                {
                                    var modeId = $"therapyMode_{stageIndex}_{mode}";
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="radio"
                                               id="@modeId"
                                               name="@($"therapyMode_{stageIndex}")"
                                               checked="@(stage.Mode == mode)"
                                               @onchange="() => OnTherapyModeChanged(stageIndex, mode)" />
                                        <label class="form-check-label" for="@modeId">@GetTherapyModeLabel(mode)</label>
                                    </div>
                                }
                            </div>

                            @if (stageIndex > 0)
                            {
                                <div class="mb-2">
                                    <label class="form-label small" for="@($"transitionReason_{stageIndex}")">
                                        Reason for modality change <span class="text-muted">(optional)</span>
                                    </label>
                                    <select class="form-select form-select-sm"
                                            id="@($"transitionReason_{stageIndex}")"
                                            @bind="stage.TransitionReason">
                                        <option value="">Select a reason</option>
                                        @foreach (var reason in TransitionReasons)
                                        {
                                            <option value="@reason">@reason</option>
                                        }
                                    </select>
                                </div>

                                @if (stage.TransitionReason == "Other")
                                {
                                    <div class="mb-2">
                                        <label class="form-label small" for="@($"transitionReasonOther_{stageIndex}")">
                                            Other reason
                                        </label>
                                        <input class="form-control form-control-sm"
                                               id="@($"transitionReasonOther_{stageIndex}")"
                                               type="text"
                                               @bind="stage.OtherTransitionReason" />
                                    </div>
                                }
                            }

                            @if (stage.Mode == PapTherapyMode.Cpap)
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <label class="form-label small">Initial CPAP</label>
                                        <select class="form-select form-select-sm" @bind="stage.InitialCpap">
                                            @foreach (var p in _config.PressureValues)
                                            {
                                                <option value="@p">@p</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label small">Final CPAP</label>
                                        <select class="form-select form-select-sm" @bind="stage.FinalCpap">
                                            @foreach (var p in _config.PressureValues)
                                            {
                                                <option value="@p">@p</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-6 col-md-3">
                                        <label class="form-label small" for="@($"initialIpap_{stageIndex}")">Initial IPAP</label>
                                        <select class="form-select form-select-sm"
                                                id="@($"initialIpap_{stageIndex}")"
                                                @bind="stage.InitialIpap">
                                            @foreach (var p in BipapIpapValues)
                                            {
                                                <option value="@p">@p</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <label class="form-label small" for="@($"initialEpap_{stageIndex}")">Initial EPAP</label>
                                        <select class="form-select form-select-sm"
                                                id="@($"initialEpap_{stageIndex}")"
                                                @bind="stage.InitialEpap">
                                            @foreach (var p in BipapEpapValues)
                                            {
                                                <option value="@p">@p</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <label class="form-label small" for="@($"finalIpap_{stageIndex}")">Final IPAP</label>
                                        <select class="form-select form-select-sm"
                                                id="@($"finalIpap_{stageIndex}")"
                                                @bind="stage.FinalIpap">
                                            @foreach (var p in BipapIpapValues)
                                            {
                                                <option value="@p">@p</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <label class="form-label small" for="@($"finalEpap_{stageIndex}")">Final EPAP</label>
                                        <select class="form-select form-select-sm"
                                                id="@($"finalEpap_{stageIndex}")"
                                                @bind="stage.FinalEpap">
                                            @foreach (var p in BipapEpapValues)
                                            {
                                                <option value="@p">@p</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                @if (HasLowPressureSupport(stage))
                                {
                                    <div class="alert alert-warning px-3 py-2 mb-2 small" role="status">
                                        Review pressure support: @GetLowPressureSupportMessage(stage)
                                        Values remain exactly as selected.
                                    </div>
                                }

                                @if (stage.Mode == PapTherapyMode.BipapSt)
                                {
                                    <div class="row g-2 mb-2">
                                        <div class="col-12 col-md-6">
                                            <label class="form-label small" for="@($"backupRate_{stageIndex}")">
                                                Backup rate
                                            </label>
                                            <div class="input-group input-group-sm">
                                                <input class="form-control"
                                                       id="@($"backupRate_{stageIndex}")"
                                                       type="number"
                                                       min="1"
                                                       @bind="stage.BackupRate" />
                                                <span class="input-group-text">bpm</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </section>

                        @if (GetAllowedNextModes(stage.Mode).Count > 0)
                        {
                            var hasFollowingStage = _therapyStages.Count > stageIndex + 1;
                            <div class="form-check therapy-transition-toggle mb-3">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="@($"transitionAfter_{stageIndex}")"
                                       checked="@hasFollowingStage"
                                       @onchange="e => SetTransitionAfter(stageIndex, (bool)e.Value!)" />
                                <label class="form-check-label" for="@($"transitionAfter_{stageIndex}")">
                                    @(stageIndex == 0 ? "Therapy changed during the study" : "Therapy changed again")
                                </label>
                            </div>
                        }
                    }

                    <hr class="my-3" />

                    <section class="mask-course">
                        <div class="mask-course-heading">Mask Course</div>

                        @for (var i = 0; i < _maskStages.Count; i++)
                        {
                            var stageIndex = i;
                            var stage = _maskStages[stageIndex];

                            <section class="mask-stage @(stageIndex > 0 ? "mask-stage-transition" : null)">
                                <div class="therapy-stage-heading">
                                    <span>@(stageIndex == 0 ? "Mask started with" : "Changed to")</span>
                                    <span class="badge bg-secondary">Stage @(stageIndex + 1)</span>
                                </div>

                                @if (stageIndex > 0)
                                {
                                    <div class="mb-2">
                                        <label class="form-label small" for="@($"maskTransitionReason_{stageIndex}")">
                                            Reason for mask setup change <span class="text-muted">(optional)</span>
                                        </label>
                                        <select class="form-select form-select-sm"
                                                id="@($"maskTransitionReason_{stageIndex}")"
                                                @bind="stage.TransitionReason">
                                            <option value="">Select a reason</option>
                                            @foreach (var reason in MaskTransitionReasons)
                                            {
                                                <option value="@reason">@reason</option>
                                            }
                                        </select>
                                    </div>

                                    @if (stage.TransitionReason == "Other")
                                    {
                                        <div class="mb-2">
                                            <label class="form-label small" for="@($"maskTransitionReasonOther_{stageIndex}")">
                                                Other reason
                                            </label>
                                            <input class="form-control form-control-sm"
                                                   id="@($"maskTransitionReasonOther_{stageIndex}")"
                                                   type="text"
                                                   @bind="stage.OtherTransitionReason" />
                                        </div>
                                    }
                                }

                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <label class="form-label small" for="@($"maskType_{stageIndex}")">Mask Type</label>
                                        <select class="form-select form-select-sm"
                                                id="@($"maskType_{stageIndex}")"
                                                @bind="stage.MaskType">
                                            @foreach (var t in _config.MaskTypes) { <option value="@t">@t</option> }
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label small" for="@($"maskSize_{stageIndex}")">Mask Size</label>
                                        <select class="form-select form-select-sm"
                                                id="@($"maskSize_{stageIndex}")"
                                                @bind="stage.MaskSize">
                                            @foreach (var s in _config.MaskSizes) { <option value="@s">@s</option> }
                                        </select>
                                    </div>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="@($"chinStrap_{stageIndex}")"
                                           @bind="stage.ChinStrap" />
                                    <label class="form-check-label" for="@($"chinStrap_{stageIndex}")">Chin strap used</label>
                                </div>
                            </section>

                            <div class="form-check mask-transition-toggle mb-3">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="@($"maskTransitionAfter_{stageIndex}")"
                                       checked="@(_maskStages.Count > stageIndex + 1)"
                                       @onchange="e => SetMaskTransitionAfter(stageIndex, (bool)e.Value!)" />
                                <label class="form-check-label" for="@($"maskTransitionAfter_{stageIndex}")">
                                    @(stageIndex == 0 ? "Mask setup changed during the study" : "Mask setup changed again")
                                </label>
                            </div>
                        }
                    </section>

                </fieldset>

                    <fieldset class="border rounded p-2 mb-3">
                    <legend class="w-auto px-2 fs-6 fw-semibold">Manage Config</legend>
                    <div class="row g-2 mb-2">
                        <div class="col">
                            <label class="form-label small fw-semibold mb-1">Mask Types</label>
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control" placeholder="New mask type" @bind="_newMaskType" />
                                <button class="btn btn-outline-primary btn-sm" @onclick="AddMaskType">Add</button>
                            </div>
                            <div class="mt-1">
                                @foreach (var t in _config.MaskTypes)
                                {
                                    <span class="badge bg-secondary me-1">
                                        @t
                                        <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.5em"
                                                @onclick="() => RemoveMaskType(t)"></button>
                                    </span>
                                }
                                @if (_config.MaskTypes.Count == 0)
                                {
                                    <span class="text-muted small fst-italic">No mask types configured.</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col">
                            <label class="form-label small fw-semibold mb-1">Mask Sizes</label>
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control" placeholder="New mask size" @bind="_newMaskSize" />
                                <button class="btn btn-outline-primary btn-sm" @onclick="AddMaskSize">Add</button>
                            </div>
                            <div class="mt-1">
                                @foreach (var s in _config.MaskSizes)
                                {
                                    <span class="badge bg-secondary me-1">
                                        @s
                                        <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.5em"
                                                @onclick="() => RemoveMaskSize(s)"></button>
                                    </span>
                                }
                                @if (_config.MaskSizes.Count == 0)
                                {
                                    <span class="text-muted small fst-italic">No mask sizes configured.</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="mt-2">
                        <button class="btn btn-outline-warning btn-sm" @onclick="ResetConfigToDefaults">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8 3a5 5 0 1 1-4.546 2.914.5.5 0 0 0-.908-.417A6 6 0 1 0 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 0-.41-.192L5.23 2.308a.25.25 0 0 0 0 .384l2.36 1.966A.25.25 0 0 0 8 4.466"/></svg>Reset to Defaults
                        </button>
                    </div>
                </fieldset>
            }

            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-primary" @onclick="GenerateNote" disabled="@_isGenerating">
                    @if (_isGenerating) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Generate Note
                </button>
                @if (!string.IsNullOrEmpty(_narrativeText))
                {
                    <button class="btn btn-success" @onclick="InsertIntoEditor">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M3.5 6a.5.5 0 0 0-.5.5v8a.5.5 0 0 0 .5.5h9a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5h-2a.5.5 0 0 1 0-1h2A1.5 1.5 0 0 1 14 6.5v8a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 2 14.5v-8A1.5 1.5 0 0 1 3.5 5h2a.5.5 0 0 1 0 1z"/><path fill-rule="evenodd" d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>Insert into Editor
                    </button>
                    <button class="btn btn-outline-success" @onclick="CopyToClipboard">📋 Copy</button>
                }
                <button class="btn btn-outline-secondary" @onclick="ResetForm">Reset</button>
                <button class="btn btn-outline-danger" @onclick="CancelSleepNote">Cancel</button>
            </div>

            @if (!string.IsNullOrEmpty(_statusMessage))
            {
                <div class="alert alert-info py-1 px-2 small">@_statusMessage</div>
            }

            @if (!string.IsNullOrEmpty(_narrativeText))
            {
                <div class="card">
                    <div class="card-header fw-semibold">Generated Narrative</div>
                    <div class="card-body">
                        <textarea class="form-control" rows="10" readonly>@_narrativeText</textarea>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
