<div class="protocol-selector mb-3">
    <div class="d-flex align-items-center gap-2 mb-2">
        <h6 class="mb-0"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path d="M2.5 3.5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1zm2-2a.5.5 0 0 1 0-1h7a.5.5 0 0 1 0 1zM0 13a1.5 1.5 0 0 0 1.5 1.5h13A1.5 1.5 0 0 0 16 13V6a1.5 1.5 0 0 0-1.5-1.5h-13A1.5 1.5 0 0 0 0 6zm1.5.5A.5.5 0 0 1 1 13V6a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5z"/></svg>Protocols</h6>
        @if (!_isCreating)
        {
            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="HandleStartCreate" disabled="@IsLoading">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/></svg> New
            </button>
        }
    </div>

    @if (_isCreating)
    {
        <div class="input-group input-group-sm mb-2" style="max-width: 400px;">
            <input type="text" class="form-control" placeholder="Protocol name"
                   @bind="_newProtocolName" @bind:event="oninput"
                   @onkeydown="HandleCreateKeyDown"
                   @onkeydown:preventDefault="false" />
            <button class="btn btn-primary" type="button" @onclick="HandleConfirmCreate"
                    disabled="@string.IsNullOrWhiteSpace(_newProtocolName)">Create</button>
            <button class="btn btn-outline-secondary" type="button" @onclick="HandleCancelCreate">Cancel</button>
        </div>
    }

    @if (_protocols.Count == 0)
    {
        <p class="text-muted small">No saved protocols yet.</p>
    }
    else
    {
        <div class="list-group list-group-flush" style="max-width: 600px;">
            @foreach (var protocol in _protocols)
            {
                var isActive = protocol.ProtocolId == ActiveProtocolId;
                var isRenaming = _renamingProtocolId == protocol.ProtocolId;

                <div class="list-group-item d-flex align-items-center gap-2 @(isActive ? "list-group-item-primary" : "")"
                     style="padding: 0.4rem 0.75rem;">

                    @if (isRenaming)
                    {
                        <div class="input-group input-group-sm flex-grow-1">
                            <input type="text" class="form-control" @bind="_renameText" @bind:event="oninput"
                                   @onkeydown="HandleRenameKeyDown" />
                            <button class="btn btn-primary" type="button" @onclick="HandleConfirmRename"
                                    disabled="@string.IsNullOrWhiteSpace(_renameText)">Save</button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="HandleCancelRename">Cancel</button>
                        </div>
                    }
                    else
                    {
                        <button type="button"
                                class="btn btn-sm @(isActive ? "btn-primary" : "btn-outline-secondary") flex-grow-1 text-start"
                                @onclick="() => HandleSwitchProtocol(protocol.ProtocolId)"
                                disabled="@(IsLoading || isActive)">
                            @protocol.Name
                            @if (protocol.IsDefault)
                            {
                                <span class="badge bg-success ms-1">Default</span>
                            }
                            @if (isActive)
                            {
                                <span class="badge bg-info ms-1">Active</span>
                            }
                        </button>

                        <button type="button" class="btn btn-sm btn-outline-secondary" title="Rename"
                                @onclick="() => HandleStartRename(protocol)" disabled="@IsLoading">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325"/></svg>
                        </button>

                        @if (!protocol.IsDefault)
                        {
                            <button type="button" class="btn btn-sm btn-outline-success" title="Set as Default"
                                    @onclick="() => HandleSetDefault(protocol)" disabled="@IsLoading">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.73 3.522-3.356c.33-.314.16-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.354 5.12l-4.898.696c-.441.062-.612.636-.283.95l3.523 3.356-.83 4.73zm4.905-2.767-3.686 1.894.694-3.957a.56.56 0 0 0-.163-.505L1.71 6.745l4.052-.576a.53.53 0 0 0 .393-.288L8 2.223l1.847 3.658a.53.53 0 0 0 .393.288l4.052.575-2.906 2.77a.56.56 0 0 0-.163.506l.694 3.957-3.686-1.894a.5.5 0 0 0-.461 0z"/></svg>
                            </button>
                        }

                        @if (!protocol.IsDefault && !isActive)
                        {
                            <button type="button" class="btn btn-sm btn-outline-danger" title="Delete"
                                    @onclick="() => HandleDelete(protocol)" disabled="@IsLoading">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                            </button>
                        }
                    }
                </div>
            }
        </div>
    }
</div>
