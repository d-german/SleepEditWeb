@rendermode @(new InteractiveServerRenderMode(prerender: true))

@if (!_featureOptions.Value.ProtocolEditorEnabled)
{
    <div class="alert alert-warning mt-3">
        <i class="bi bi-exclamation-triangle me-2"></i>The Protocol Editor is currently disabled.
    </div>
}
else if (_isLoading)
{
    <div class="d-flex justify-content-center align-items-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <span class="ms-3 text-muted">Loading protocol editor...</span>
    </div>
}
else
{
    <div tabindex="0" @onkeydown="HandleKeyDown" style="outline: none;">
        <div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <h1 class="page-title">Protocol Editor</h1>
                <p class="page-subtitle">Build, organize, and export protocol statements.</p>
            </div>
        </div>

        <ProtocolToolbar
            Snapshot="_snapshot"
            SelectedNodeId="_selectedNodeId"
            IsLoading="_isLoading"
            OnMutation="HandleMutation"
            OnError="HandleError"
            OnAddSection="HandleAddSectionRequested"
            OnToggleAllSections="HandleToggleAllSections" />

        @if (_addSectionPanelOpen)
        {
            <div class="input-group mb-3" style="max-width: 400px;">
                <input id="newSectionInput"
                       type="text"
                       class="form-control"
                       placeholder="Section name"
                       @bind="_newSectionText"
                       @bind:event="oninput"
                       @onkeydown="HandleAddSectionKeyDown" />
                <button class="btn btn-primary" type="button" @onclick="HandleAddSectionConfirm"
                        disabled="@string.IsNullOrWhiteSpace(_newSectionText)">
                    Add
                </button>
                <button class="btn btn-outline-secondary" type="button"
                        @onclick="() => { _addSectionPanelOpen = false; _newSectionText = string.Empty; }">
                    Cancel
                </button>
            </div>
        }

        <div class="row g-3 protocol-editor-shell">
            <div class="col-12 col-xl-4 protocol-tree-column">
                <div class="dashboard-card h-100">
                    <div class="dashboard-card-header">
                        <i class="bi bi-diagram-3 me-2"></i>Protocol Tree
                    </div>
                    <div class="dashboard-card-body">
                        <ProtocolTree Document="_snapshot.Document"
                                      SelectedNodeId="_selectedNodeId"
                                      OnNodeSelected="HandleNodeSelected"
                                      OnNodeMoved="HandleNodeMoved" />
                    </div>
                </div>
            </div>
            <div class="col-12 col-xl-8 protocol-details-column">
                <ProtocolNodeInfoPanel SelectedNode="GetSelectedNode(_snapshot.Document, _selectedNodeId)"
                                       Document="_snapshot.Document"
                                       OnMutation="HandleMutation"
                                       OnError="HandleError" />
            </div>
        </div>

        <div class="small text-muted mt-3">@_statusMessage</div>
    </div>
}
