@rendermode @(new InteractiveServerRenderMode(prerender: true))

@if (!FeatureOptions.Value.ProtocolEditorEnabled)
{
    <div class="alert alert-warning mt-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16"><path d="M7.938 2.016A.13.13 0 0 1 8.002 2a.13.13 0 0 1 .063.016.15.15 0 0 1 .054.057l6.857 11.667c.036.06.035.124.002.183a.2.2 0 0 1-.054.06.1.1 0 0 1-.066.017H1.146a.1.1 0 0 1-.066-.017.2.2 0 0 1-.054-.06.18.18 0 0 1 .002-.183L7.884 2.073a.15.15 0 0 1 .054-.057m1.044-.45a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767z"/><path d="M7.002 12a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 5.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/></svg>The Protocol Editor is currently disabled.
    </div>
}
else if (_isLoading)
{
    <div class="d-flex justify-content-center align-items-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <span class="ms-3 text-muted">Loading protocol editor...</span>
    </div>
}
else
{
    <div tabindex="0" @onkeydown="HandleKeyDown" style="outline: none;">
        <div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <h1 class="page-title">Protocol Editor</h1>
                <p class="page-subtitle">
                    @if (!string.IsNullOrEmpty(_activeProtocolName))
                    {
                        <span>Editing: <strong>@_activeProtocolName</strong></span>
                    }
                    else
                    {
                        <span>Build, organize, and export protocol statements.</span>
                    }
                </p>
            </div>
        </div>

        <ProtocolSelector @ref="_protocolSelector"
                          ActiveProtocolId="_activeProtocolId"
                          IsLoading="_isLoading"
                          OnProtocolSwitched="HandleProtocolSwitched"
                          OnError="HandleError" />

        <ProtocolToolbar
            Snapshot="_snapshot"
            SelectedNodeId="_selectedNodeId"
            IsLoading="_isLoading"
            ActiveProtocolId="_activeProtocolId"
            OnMutation="HandleMutation"
            OnSetDefault="HandleDefaultChanged"
            OnError="HandleError"
            OnAddSection="HandleAddSectionRequested"
            OnToggleAllSections="HandleToggleAllSections" />

        @if (_addSectionPanelOpen)
        {
            <div class="input-group mb-3" style="max-width: 400px;">
                <input id="newSectionInput"
                       type="text"
                       class="form-control"
                       placeholder="Section name"
                       @bind="_newSectionText"
                       @bind:event="oninput"
                       @onkeydown="HandleAddSectionKeyDown" />
                <button class="btn btn-primary" type="button" @onclick="HandleAddSectionConfirm"
                        disabled="@string.IsNullOrWhiteSpace(_newSectionText)">
                    Add
                </button>
                <button class="btn btn-outline-secondary" type="button"
                        @onclick="() => { _addSectionPanelOpen = false; _newSectionText = string.Empty; }">
                    Cancel
                </button>
            </div>
        }

        <div class="row g-3 protocol-editor-shell">
            <div class="col-12 col-xl-4 protocol-tree-column">
                <div class="dashboard-card h-100">
                    <div class="dashboard-card-header">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M6 3.5A1.5 1.5 0 0 1 7.5 2h1A1.5 1.5 0 0 1 10 3.5v1A1.5 1.5 0 0 1 8.5 6v1H14a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-1 0V8h-5v.5a.5.5 0 0 1-1 0V8h-5v.5a.5.5 0 0 1-1 0v-1A.5.5 0 0 1 2 7h5.5V6A1.5 1.5 0 0 1 6 4.5zM8.5 5a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5zM0 11.5A1.5 1.5 0 0 1 1.5 10h1A1.5 1.5 0 0 1 4 11.5v1A1.5 1.5 0 0 1 2.5 14h-1A1.5 1.5 0 0 1 0 12.5zm1.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zm4.5.5A1.5 1.5 0 0 1 7.5 10h1a1.5 1.5 0 0 1 1.5 1.5v1A1.5 1.5 0 0 1 8.5 14h-1A1.5 1.5 0 0 1 6 12.5zm1.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zm4.5.5a1.5 1.5 0 0 1 1.5-1.5h1a1.5 1.5 0 0 1 1.5 1.5v1a1.5 1.5 0 0 1-1.5 1.5h-1a1.5 1.5 0 0 1-1.5-1.5zm1.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5z"/></svg>Protocol Tree
                    </div>
                    <div class="dashboard-card-body">
                        <ProtocolTree Document="_snapshot.Document"
                                      SelectedNodeId="_selectedNodeId"
                                      OnNodeSelected="HandleNodeSelected"
                                      OnNodeMoved="HandleNodeMoved" />
                    </div>
                </div>
            </div>
            <div class="col-12 col-xl-8 protocol-details-column">
                <ProtocolNodeInfoPanel SelectedNode="GetSelectedNode(_snapshot.Document, _selectedNodeId)"
                                       Document="_snapshot.Document"
                                       OnMutation="HandleMutation"
                                       OnError="HandleError" />
            </div>
        </div>

        <div class="small text-muted mt-3">@_statusMessage</div>
    </div>
}
