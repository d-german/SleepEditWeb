@if (SelectedNode is null)
{
    <div class="dashboard-card">
        <div class="dashboard-card-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16"><path d="M5.5 7a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1zM5 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0 2a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5"/><path d="M9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5zm0 1v2A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1z"/></svg>Statement Info
        </div>
        <div class="dashboard-card-body">
            <div class="text-muted small fst-italic p-3">Select a node in the tree to edit its properties.</div>
        </div>
    </div>
}
else
{
    <!-- Card 1: Statement Info -->
    <div class="dashboard-card">
        <div class="dashboard-card-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16"><path d="M5.5 7a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1zM5 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0 2a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5"/><path d="M9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5zm0 1v2A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1z"/></svg>Statement Info
        </div>
        <div class="dashboard-card-body">
            <div class="row g-3">
                <div class="col-12 col-md-3">
                    <label class="form-label">Statement Id</label>
                    <input type="text" class="form-control" value="@SelectedNode.Id" readonly />
                </div>
                <div class="col-12">
                    <label for="nodeTextInput" class="form-label">Statement Text</label>
                    <textarea id="nodeTextInput"
                              class="form-control"
                              rows="5"
                              @bind="_nodeText"
                              @bind:event="oninput"
                              @onblur="HandleTextBlur"></textarea>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 2: SubText Info -->
    <div class="dashboard-card mt-3">
        <div class="dashboard-card-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M5 11.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5M3.854 2.146a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0l-.5-.5a.5.5 0 1 1 .708-.708L2 3.293l1.146-1.147a.5.5 0 0 1 .708 0m0 4a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0l-.5-.5a.5.5 0 1 1 .708-.708L2 7.293l1.146-1.147a.5.5 0 0 1 .708 0m0 4a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0l-.5-.5a.5.5 0 0 1 .708-.708l.146.147 1.146-1.147a.5.5 0 0 1 .708 0"/></svg>SubText Info
        </div>
        <div class="dashboard-card-body">
            <div class="row g-3">
                <div class="col-12 col-lg-7">
                    <label class="form-label">SubText Items</label>
                    <select class="form-select"
                            size="5"
                            @onchange="e => _selectedSubText = e.Value?.ToString() ?? string.Empty">
                        @foreach (var item in SelectedNode.SubText)
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-5">
                    <label class="form-label">New Item</label>
                    <input type="text" class="form-control mb-2" @bind="_newSubText" @bind:event="oninput" />
                    <div class="d-flex gap-2">
                        <button type="button"
                                class="btn btn-outline-primary btn-sm"
                                @onclick="HandleAddSubText"
                                disabled="@string.IsNullOrWhiteSpace(_newSubText)">
                            Add Item
                        </button>
                        <button type="button"
                                class="btn btn-outline-danger btn-sm"
                                @onclick="HandleRemoveSubText"
                                disabled="@string.IsNullOrWhiteSpace(_selectedSubText)">
                            Remove Item
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 3: Link Info -->
    <div class="dashboard-card mt-3">
        <div class="dashboard-card-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16"><path d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1 1 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4 4 0 0 1-.128-1.287z"/><path d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243z"/></svg>Link Info
        </div>
        <div class="dashboard-card-body">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label class="form-label">Statement Id</label>
                    <input type="text" class="form-control" value="@SelectedNode.Id" readonly />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Link Id</label>
                    <input type="text" class="form-control"
                           value="@(SelectedNode.LinkId > 0 ? SelectedNode.LinkId.ToString() : string.Empty)"
                           readonly />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Link Text</label>
                    <input type="text" class="form-control" value="@SelectedNode.LinkText" readonly />
                </div>
            </div>
            <div class="d-flex gap-2 mt-2">
                <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => _linkPickerOpen = true">
                    Select Link...
                </button>
                @if (SelectedNode.LinkId > 0)
                {
                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="HandleClearLink">
                        Clear Link
                    </button>
                }
            </div>
        </div>
    </div>
}

@if (_linkPickerOpen && SelectedNode is not null)
{
    <ProtocolLinkPicker Document="Document"
                        SourceNode="SelectedNode"
                        OnLinkSelected="HandleLinkSelected"
                        OnCancelled="@(() => _linkPickerOpen = false)" />
}
