<div class="protocol-tree-host">
    @if (Document.Sections.Count == 0)
    {
        <div class="text-muted small fst-italic p-3">
            No sections yet. Click <strong>Add Section</strong> to begin.
        </div>
    }
    else
    {
        @foreach (var sec in Document.Sections)
        {
            var secId = sec.Id;
            var isCollapsed = _collapsedSectionIds.Contains(secId);
            var listId = GetSectionListId(secId);

            <div class="protocol-section mb-2">
                <div class="protocol-section-header d-flex align-items-center gap-1 py-1 px-2 @(SelectedNodeId == secId ? "selected" : null)"
                     style="user-select: none;">
                    <button type="button"
                            class="protocol-section-toggle"
                            title="@(isCollapsed ? "Expand section" : "Collapse section")"
                            aria-label="@(isCollapsed ? "Expand section" : "Collapse section")"
                            @onclick="@(() => HandleSectionToggle(secId))">
                        <i class="bi @(isCollapsed ? "bi-chevron-right" : "bi-chevron-down")"></i>
                    </button>
                    <button type="button"
                            class="protocol-section-select"
                            @onclick="@(() => HandleSectionSelected(secId))">
                        <span class="fw-semibold flex-grow-1 text-start">@sec.Text</span>
                        <span class="badge bg-secondary">@CountDescendants(sec)</span>
                    </button>
                </div>
                @if (!isCollapsed)
                {
                    <div id="@listId"
                         class="protocol-node-list ps-2"
                         data-parent-id="@sec.Id">
                        @foreach (var node in sec.Children)
                        {
                            <div data-node-id="@node.Id">
                                <ProtocolNodeItem Node="node"
                                                  SelectedNodeId="SelectedNodeId"
                                                  OnNodeSelected="OnNodeSelected"
                                                  Depth="1" />
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>
