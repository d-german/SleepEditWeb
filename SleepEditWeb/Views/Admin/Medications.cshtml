@section Scripts {
    <script>
        function confirmImport() {
            var mode = $('input[name="mode"]:checked').val();
            if (mode === 'replace') {
                return confirm('WARNING: Replace mode will DELETE ALL existing medications and restore from backup.\n\nThis action cannot be undone!\n\nAre you sure you want to continue?');
            }
            return confirm('This will merge the backup with existing medications.\n\nNew medications will be added. Existing medications will be preserved.\n\nContinue?');
        }

        function confirmReseed() {
            return confirm('WARNING: This will DELETE ALL medications (including user-added) and reset to the original seed data.\n\nThis action cannot be undone!\n\nAre you sure you want to reseed the database?');
        }

        function confirmClearUserMeds() {
            var userCount = @Model.UserMedCount;
            if (userCount === 0) {
                alert('There are no user-added medications to clear.');
                return false;
            }
            return confirm('This will remove ' + userCount + ' user-added medication(s).\n\nSystem medications will NOT be affected.\n\nContinue?');
        }
    </script>
}

